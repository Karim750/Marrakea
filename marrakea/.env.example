# MARRAKEA Frontend Environment Variables

# ─────────────────────────────────────────────────────────────────────────────
# BFF API Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Server-side BFF URL (used in Server Components)
# This variable is NOT exposed to the browser
BFF_URL=http://localhost:4000

# Client-side BFF URL (used in Client Components)
# This variable IS exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BFF_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────────────────────
# Payment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Stripe publishable key (for Stripe Payment Element)
# This variable IS exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────

# Use mock data instead of real BFF
# Set to 'false' to connect to real BFF (operational on localhost:4000)
# Set to 'true' to use mock data (for testing without BFF)
NEXT_PUBLIC_USE_MOCK=false

# ─────────────────────────────────────────────────────────────────────────────
# Environment-Specific Examples
# ─────────────────────────────────────────────────────────────────────────────

# Development (local BFF operational)
# BFF_URL=http://localhost:4000
# NEXT_PUBLIC_BFF_URL=http://localhost:4000
# NEXT_PUBLIC_USE_MOCK=false
#
# Development (mock data, no BFF required)
# BFF_URL=http://localhost:4000
# NEXT_PUBLIC_BFF_URL=http://localhost:4000
# NEXT_PUBLIC_USE_MOCK=true

# Staging
# BFF_URL=https://api-staging.marrakea.com
# NEXT_PUBLIC_BFF_URL=https://api-staging.marrakea.com
# NEXT_PUBLIC_USE_MOCK=false

# Production
# BFF_URL=https://api.marrakea.com
# NEXT_PUBLIC_BFF_URL=https://api.marrakea.com
# NEXT_PUBLIC_USE_MOCK=false

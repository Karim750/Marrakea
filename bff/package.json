{
  "name": "marrakea-bff",
  "version": "1.0.0",
  "description": "Backend-For-Frontend for Marrakea Next.js frontend",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "test:postman": "newman run tests/postman/MARRAKEA_BFF.postman_collection.json -e tests/postman/MARRAKEA_BFF.postman_environment.json"
  },
  "dependencies": {
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.56.0",
    "newman": "^6.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

                  "pm.test('ProductDTO has required fields', function () {",
                  "    const json = pm.response.json();",
                  "    if (json.data.length > 0) {",
                  "        const product = json.data[0];",
                  "        pm.expect(product).to.have.property('id');",
                  "        pm.expect(product).to.have.property('slug');",
                  "        pm.expect(product).to.have.property('title');",
                  "        pm.expect(product).to.have.property('coverImage');",
                  "        pm.expect(product).to.have.property('price');",
                  "        pm.expect(product).to.have.property('availability');",
                  "        pm.expect(product).to.have.property('gesture');",
                  "        pm.expect(product).to.have.property('territory');",
                  "        pm.expect(product.price).to.have.property('formattedPrice');",
